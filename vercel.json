{
  "rewrites": [
    { "source": "/app.js",  "destination": "/app/app.js"  },
    { "source": "/app.css", "destination": "/app/app.css" },
    { "source": "/((?!api/).*)", "destination": "/app/index.html" }
  ],
  "headers": [
    {
      "source": "/app/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=86400" }]
    }
  ]
}
